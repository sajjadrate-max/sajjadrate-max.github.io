<body>
<div class="container">
  <div class="header-badge">⚖️</div>
  <h1 data-i18n="title">موٹاپا کم کریں</h1>
  <div class="subtitle" data-i18n="subtitle">اپنی معلومات درج کریں اور مکمل خوراک و ورزش پلان حاصل کریں</div>

  <div class="lang-select-wrap">
    <div id="langDisplay" onclick="toggleLangDropdown()">🌐 <span id="langCurrentName">اردو (Urdu)</span> ▾</div>
    <div id="langDropdownPanel">
      <input type="text" id="langSearchInput" placeholder="Search language... / زبان تلاش کریں" oninput="filterLangList()" />
      <div id="langListItems"></div>
    </div>
  </div>

  <div id="page-home" class="page active">
  <div class="card">
    <div class="field">
      <label data-i18n="labelWeight">وزن (کلوگرام)</label>
      <input type="number" id="weight" placeholder="مثلاً 85" />
    </div>
    <div class="field">
      <label data-i18n="labelAge">عمر (سال)</label>
      <input type="number" id="age" placeholder="مثلاً 30" />
    </div>

    <div class="field">
      <label data-i18n="labelHeightUnit">قد کی اکائی</label>
      <select id="heightUnit" onchange="toggleHeightUnit()">
        <option value="cm" data-i18n="optCm">سینٹی میٹر</option>
        <option value="ft" data-i18n="optFt">فٹ</option>
      </select>
    </div>

    <div class="field" id="heightCmField">
      <label data-i18n="labelHeightCm">قد (سینٹی میٹر)</label>
      <input type="number" id="height" placeholder="مثلاً 170" />
    </div>

    <div class="row2" id="heightFtField" style="display:none;">
      <div class="field">
        <label data-i18n="labelHeightFt">قد (فٹ)</label>
        <input type="number" id="heightFeet" placeholder="مثلاً 5" />
      </div>
      <div class="field">
        <label data-i18n="labelInches">انچ</label>
        <input type="number" id="heightInches" placeholder="مثلاً 7" />
      </div>
    </div>
    <div class="field">
      <label data-i18n="labelGender">جنس</label>
      <select id="gender">
        <option value="male" data-i18n="optMale">مرد</option>
        <option value="female" data-i18n="optFemale">عورت</option>
      </select>
    </div>
    <div class="field">
      <label data-i18n="labelActivity">کام کاج (روزمرہ سرگرمی)</label>
      <select id="activity">
        <option value="1.2" data-i18n="optAct1">دفتری کام / زیادہ تر بیٹھے رہنا</option>
        <option value="1.375" data-i18n="optAct2">ہلکی مشقت (تھوڑی چہل قدمی، گھریلو کام)</option>
        <option value="1.55" data-i18n="optAct3">درمیانی مشقت (روزانہ جسمانی کام یا ورزش)</option>
        <option value="1.725" data-i18n="optAct4">بھاری مشقت (مزدوری، کھیل، سخت جسمانی کام)</option>
      </select>
    </div>
    <button onclick="calculate()" data-i18n="btnCalculate">حساب لگائیں</button>
  </div>

  <div id="results">
    <div class="card">
      <div class="result-title" data-i18n="titleDailyNeed">آپ کی روزانہ ضرورت</div>
      <div class="highlight-box">
        <div data-i18n="labelMaintainCal">موجودہ وزن برقرار رکھنے کے لیے روزانہ کیلوریز</div>
        <div class="big" id="tdee">-</div>
      </div>
      <div class="note" data-i18n="noteTdee">یہ آپ کی BMR اور روزمرہ سرگرمی کے حساب سے ہے</div>
    </div>

    <div class="card">
      <div class="result-title" data-i18n="titleWeightLossPlan">وزن کم کرنے کا پلان</div>
      <div class="stat"><span data-i18n="labelTargetCal">روزانہ کیلوریز (وزن کم کرنے کے لیے)</span><span class="val" id="targetCal">-</span></div>
      <div class="stat"><span data-i18n="labelProtein">پروٹین (گرام)</span><span class="val" id="protein">-</span></div>
      <div class="stat"><span data-i18n="labelFat">فیٹ (گرام)</span><span class="val" id="fat">-</span></div>
      <div class="stat"><span data-i18n="labelCarbs">کاربوہائیڈریٹ (گرام)</span><span class="val" id="carbs">-</span></div>
      <div class="note" id="weeklyLoss"></div>
    </div>

    <div class="card">
      <div class="result-title" data-i18n="titleFoodSelect">اپنی مرضی کی غذا منتخب کریں</div>
      <div class="note" style="margin-bottom:15px;" data-i18n="notePickMethod">پہلے طریقہ منتخب کریں</div>
      <div class="choice-btn" onclick="autoSelectFoods()">
        <div class="choice-icon">🤖</div>
        <div>
          <div class="choice-title" data-i18n="titleAutoSelect">خودکار انتخاب</div>
          <div class="choice-sub" data-i18n="subAutoSelect">ویب سائٹ موسم کے مطابق غذا خود منتخب کرے</div>
        </div>
      </div>
      <div class="choice-btn" onclick="manualSelectMode()">
        <div class="choice-icon">✋</div>
        <div>
          <div class="choice-title" data-i18n="titleManualSelect">دستی انتخاب</div>
          <div class="choice-sub" data-i18n="subManualSelect">میں خود دیکھ کر ہر غذا منتخب کروں گا</div>
        </div>
      </div>
      <div class="note" id="planLabel" style="margin-bottom:15px;"></div>
      <div class="note" style="margin-bottom:15px;" data-i18n="noteFoodQty">ہر غذا کے سامنے مقدار (تعداد) درج کریں۔ صرف وہ چیزیں شمار ہوں گی جن کی مقدار 0 سے زیادہ ہو</div>
      <div id="foodList"></div>
      <button onclick="calculateDiet()" style="margin-top:10px;" data-i18n="btnCalcDiet">میری خوراک کا حساب لگائیں</button>
    </div>

    <div class="card" id="dietResultCard" style="display:none;">
      <div class="result-title" data-i18n="titleDietSummary">آپ کی منتخب کردہ غذا کا مجموعہ</div>
      <div class="stat"><span data-i18n="labelTotalCal">کل کیلوریز</span><span class="val" id="dietCal">-</span></div>
      <div class="stat"><span data-i18n="labelProtein">پروٹین (گرام)</span><span class="val" id="dietProtein">-</span></div>
      <div class="stat"><span data-i18n="labelFat">فیٹ (گرام)</span><span class="val" id="dietFat">-</span></div>
      <div class="stat"><span data-i18n="labelCarbs">کاربوہائیڈریٹ (گرام)</span><span class="val" id="dietCarbs">-</span></div>
      <div class="note" id="dietCompare" style="margin-top:12px; color:#d4af37; font-weight:bold;"></div>
      <div id="dietStatusList" style="margin-top:14px;"></div>
    </div>

    <div class="card">
      <div class="result-title" data-i18n="titleExercise">روزانہ ورزش</div>
      <div class="walk-box">
        <div data-i18n="labelWalkDistance">روزانہ پیدل چلنے کا فاصلہ</div>
        <div class="big"><span id="walkKm">-</span> <span data-i18n="unitKm">کلومیٹر</span></div>
        <div class="note" id="walkMin"></div>
        <div class="note" id="walkSteps" style="margin-top:6px;"></div>
      </div>
      <div class="note" id="brisknote" style="margin-top:12px; color:#d4af37; font-weight:bold;"></div>
    </div>

    <div class="card" id="selectedFoodsCard" style="display:none;">
      <div class="result-title" data-i18n="titleSelectedFoods">آپ کی منتخب کردہ غذائیں</div>
      <div id="selectedFoodsList"></div>
    </div>

    <div class="card" id="finalSummaryCard" style="display:none;">
      <div class="result-title" data-i18n="titleFinalSummary">حتمی خلاصہ</div>
      <div class="note" id="kcalRuleText" style="margin-bottom:14px;"></div>
      <div class="highlight-box">
        <div id="finalWeekLabel" data-i18n="labelWeeklyLoss">ایک ہفتے میں متوقع وزن کمی</div>
        <div class="big" id="finalWeekLoss">-</div>
      </div>
      <div class="highlight-box" style="margin-top:10px;">
        <div id="finalMonthLabel" data-i18n="labelMonthlyLoss">ایک مہینے میں متوقع وزن کمی</div>
        <div class="big" id="finalMonthLoss">-</div>
      </div>
      <div class="note" id="finalSummaryNote" style="margin-top:12px;"></div>
    </div>

    <div class="footer-note" data-i18n="footerDisclaimer">یہ کیلکولیٹر عمومی رہنمائی کے لیے ہے۔ کسی بھی سنگین طبی مسئلے یا خاص جسمانی حالت کی صورت میں ڈاکٹر یا ماہرِ غذائیت سے مشورہ ضرور کریں۔</div>
  </div>
  </div>
  <!-- end page-home -->

  <div id="page-about" class="page" dir="ltr">
    <div class="card static-page">
      <h2>About Us</h2>
      <div id="aboutContent"></div>
    </div>
  </div>

  <div id="page-terms" class="page" dir="ltr">
    <div class="card static-page">
      <h2>Terms & Conditions</h2>
      <div id="termsContent"></div>
    </div>
  </div>

  <div id="page-privacy" class="page" dir="ltr">
    <div class="card static-page">
      <h2>Privacy Policy</h2>
      <div id="privacyContent"></div>
    </div>
  </div>

  <div id="page-disclaimer" class="page" dir="ltr">
    <div class="card static-page">
      <h2>Disclaimer</h2>
      <div id="disclaimerContent"></div>
    </div>
  </div>

  <div id="page-contact" class="page" dir="ltr">
    <div class="card static-page">
      <h2>Contact Us</h2>
      <p id="contactIntroText">We would love to hear from you. Whether you have a question about how the calculator works, a suggestion for a new feature, or feedback on a result, please use the form below to send us a message directly.</p>

      <form id="contactForm">
        <div class="field">
          <label style="text-align:left;" data-i18n="contactName">Name</label>
          <input type="text" name="name" id="cf_name" placeholder="Your name" required />
        </div>
        <div class="field">
          <label style="text-align:left;" data-i18n="contactEmail">Email</label>
          <input type="email" name="email" id="cf_email" placeholder="you@example.com" required />
