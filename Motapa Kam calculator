<meta name="description" content="Free weight loss and calorie calculator. Calculate your daily calories, protein, fat, carbs, and get a personalized diet and walking plan. Available in Urdu and multiple languages.">
<meta name="keywords" content="weight loss calculator, calorie calculator, BMR calculator, TDEE calculator, diet plan, Urdu calorie calculator, macros calculator">
